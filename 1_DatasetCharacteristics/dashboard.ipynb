import streamlit as st
import pandas as pd
import matplotlib.pyplot as plt

data = pd.read_csv("../0_DataPreparation/data/data_final_mit_LAG/df_final.csv")

# Titel
st.title("Bakery Sales Dashboard")

# Daten laden
df = pd.read_csv("bakery_sales.csv")

# Sidebar Filter
st.sidebar.header("Filter")

weekday = st.sidebar.selectbox(
    "Select weekday",
    data["weekday"].unique()
)

product = st.sidebar.selectbox(
    "Select product",
    data["product"].unique()
)

# Daten filtern
filtered_data = data[
    (data["weekday"] == weekday) &
    (data["product"] == product)
]

st.subheader("Filtered Sales Data")
st.write(filtered_data)

# Plot
fig, ax = plt.subplots()
ax.plot(filtered_data["date"], filtered_data["sales"])
ax.set_xlabel("Date")
ax.set_ylabel("Sales")
ax.set_title("Sales over Time")

st.pyplot(fig)